<div class="chart-block">
  <div class="legend">
    <span><i class="swatch" style="background:var(--red-line)"></i> Polio cases, 1948</span>
    <span><i class="swatch" style="background:var(--ink)"></i> Polio cases, 1949</span>
  </div>
  <figure>
    <svg
      id="chart"
      viewBox="0 0 760 470"
      role="img"
      aria-label="Bar chart comparing North Carolina polio cases: 2,498 in 1948 versus 229 in 1949, a 91 percent drop."
    ></svg>
    <figcaption class="cap">A real 91% drop, credited to sugar. Polio is seasonal and epidemics regress after a peak year; the same two summers would have produced roughly this drop with no one changing their diet at all.</figcaption>
  </figure>
</div>

<script is:inline>
(function(){
  // ---- DATA (North Carolina, polio cases) ----
  var y1948 = 2498;
  var y1949 = 229;

  var W=760, H=470, m={t:24,r:20,b:50,l:60};
  var pw=W-m.l-m.r, ph=H-m.t-m.b;
  var yMax=2500;
  function Y(v){return m.t + (1-v/yMax)*ph;}

  var svg=document.getElementById('chart');
  var NS='http://www.w3.org/2000/svg';
  function el(t,a){var e=document.createElementNS(NS,t);for(var k in a)e.setAttribute(k,a[k]);return e;}

  // gridlines + y labels
  for(var g=0; g<=2500; g+=500){
    svg.appendChild(el('line',{x1:m.l,y1:Y(g),x2:W-m.r,y2:Y(g),stroke:'#C6C7BF','stroke-width':1}));
    var yl=el('text',{x:m.l-8,y:Y(g)+4,'text-anchor':'end','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
    yl.textContent=g; svg.appendChild(yl);
  }
  // y axis title
  var yt=el('text',{x:m.l-8,y:Y(2500)-8,'text-anchor':'end','font-family':"'IBM Plex Mono',monospace",'font-size':10.5,fill:'#5A5C55'});
  yt.textContent='cases'; svg.appendChild(yt);

  // bar geometry
  var c1 = m.l + pw*0.28;
  var c2 = m.l + pw*0.72;
  var barWidth = 140;
  var base = Y(0);

  // 1948 bar (red)
  var b1 = Y(y1948);
  svg.appendChild(el('rect',{x:c1-barWidth/2,y:b1,width:barWidth,height:base-b1,fill:'#C22B24',class:'fade'}));
  var v1=el('text',{x:c1,y:b1-10,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':15,'font-weight':700,fill:'#C22B24'});
  v1.textContent=y1948; svg.appendChild(v1);
  var l1=el('text',{x:c1,y:H-m.b+22,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
  l1.textContent='1948'; svg.appendChild(l1);

  // 1949 bar (ink)
  var b2 = Y(y1949);
  svg.appendChild(el('rect',{x:c2-barWidth/2,y:b2,width:barWidth,height:base-b2,fill:'#17181A',class:'fade'}));
  var v2=el('text',{x:c2,y:b2-10,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':15,'font-weight':700,fill:'#17181A'});
  v2.textContent=y1949; svg.appendChild(v2);
  var l2=el('text',{x:c2,y:H-m.b+22,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
  l2.textContent='1949'; svg.appendChild(l2);
})();
</script>
