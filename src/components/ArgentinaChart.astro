<div class="chart-block">
  <div class="legend">
    <span><i class="swatch" style="background:var(--red-line)"></i> Official inflation (INDEC)</span>
    <span><i class="swatch" style="background:var(--ink)"></i> Private-sector estimate</span>
  </div>
  <figure>
    <svg
      id="chart"
      viewBox="0 0 760 470"
      role="img"
      aria-label="Grouped bar chart comparing Argentina's 2012 inflation rate: INDEC official figure of 10.8 percent versus the private-sector estimate of 25.6 percent."
    ></svg>
    <figcaption class="cap">One of these numbers determined what Argentina paid on its own debt. There was no dataset clean enough to chart the other nine years, which is itself the point.</figcaption>
  </figure>
</div>

<script is:inline>
(function(){
  // ---- DATA (2012, percent) ----
  var indec = 10.8;
  var priv  = 25.6;

  var W=760, H=470, m={t:24,r:20,b:50,l:52};
  var pw=W-m.l-m.r, ph=H-m.t-m.b;
  var yMax=30;
  function Y(v){return m.t + (1-v/yMax)*ph;}

  var svg=document.getElementById('chart');
  var NS='http://www.w3.org/2000/svg';
  function el(t,a){var e=document.createElementNS(NS,t);for(var k in a)e.setAttribute(k,a[k]);return e;}

  // gridlines + y labels
  for(var g=0; g<=30; g+=10){
    svg.appendChild(el('line',{x1:m.l,y1:Y(g),x2:W-m.r,y2:Y(g),stroke:'#C6C7BF','stroke-width':1}));
    var yl=el('text',{x:m.l-8,y:Y(g)+4,'text-anchor':'end','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
    yl.textContent=g; svg.appendChild(yl);
  }
  // y axis title
  var yt=el('text',{x:m.l-8,y:Y(30)-8,'text-anchor':'end','font-family':"'IBM Plex Mono',monospace",'font-size':10.5,fill:'#5A5C55'});
  yt.textContent='%'; svg.appendChild(yt);

  // bar geometry
  var c1 = m.l + pw*0.28;
  var c2 = m.l + pw*0.72;
  var barWidth = 140;
  var base = Y(0);

  // INDEC bar (red)
  var y1 = Y(indec);
  svg.appendChild(el('rect',{x:c1-barWidth/2,y:y1,width:barWidth,height:base-y1,fill:'#C22B24',class:'fade'}));
  var v1=el('text',{x:c1,y:y1-10,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':15,'font-weight':700,fill:'#C22B24'});
  v1.textContent=indec+'%'; svg.appendChild(v1);
  var l1=el('text',{x:c1,y:H-m.b+22,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
  l1.textContent='INDEC OFFICIAL'; svg.appendChild(l1);

  // Private estimate bar (ink)
  var y2 = Y(priv);
  svg.appendChild(el('rect',{x:c2-barWidth/2,y:y2,width:barWidth,height:base-y2,fill:'#17181A',class:'fade'}));
  var v2=el('text',{x:c2,y:y2-10,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':15,'font-weight':700,fill:'#17181A'});
  v2.textContent=priv+'%'; svg.appendChild(v2);
  var l2=el('text',{x:c2,y:H-m.b+22,'text-anchor':'middle','font-family':"'IBM Plex Mono',monospace",'font-size':11,fill:'#5A5C55'});
  l2.textContent='PRIVATE ESTIMATE'; svg.appendChild(l2);
})();
</script>
