---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A museum of statistical discrepancies.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site">
      <div class="masthead">
        <a href={withBase('/')}><span class="brand">Rounding Errors</span></a>
        <span class="meta">A museum of statistical discrepancies</span>
      </div>

      <div class="layout">
        <Sidebar />
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
