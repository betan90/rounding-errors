---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExhibitCard from '../../components/ExhibitCard.astro';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const exhibits = await getCollection('exhibits');
  const tags = [...new Set(exhibits.flatMap((e) => e.data.tags))];

  return tags.map((tag) => {
    const matches = exhibits
      .filter((e) => e.data.tags.includes(tag))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return {
      params: { tag },
      props: { tag, exhibits: matches },
    };
  });
}

const { tag, exhibits } = Astro.props;
---

<BaseLayout title={`#${tag} · Rounding Errors`} description={`Exhibits tagged ${tag}.`}>
  <div class="listing-head">
    <div class="kicker">Filtered by tag</div>
    <h1>{tag}</h1>
  </div>
  <div class="feed">
    {
      exhibits.map((entry) => (
        <ExhibitCard
          exhibit={entry.data.exhibit}
          country={entry.data.country}
          title={entry.data.title}
          category={entry.data.category}
          teaser={entry.data.teaser}
          date={entry.data.date}
          href={withBase(`/exhibits/${entry.slug}/`)}
        />
      ))
    }
  </div>
</BaseLayout>
