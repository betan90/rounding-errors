---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExhibitCard from '../../components/ExhibitCard.astro';
import { withBase, slugify } from '../../lib/paths';

export async function getStaticPaths() {
  const exhibits = await getCollection('exhibits');
  const countries = [...new Set(exhibits.map((e) => e.data.country))];

  return countries.map((country) => {
    const slug = slugify(country);
    const matches = exhibits
      .filter((e) => e.data.country === country)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return {
      params: { country: slug },
      props: { country, exhibits: matches },
    };
  });
}

const { country, exhibits } = Astro.props;
---

<BaseLayout title={`${country} · Rounding Errors`} description={`Exhibits filed under ${country}.`}>
  <div class="listing-head">
    <div class="kicker">Filtered by country</div>
    <h1>{country}</h1>
  </div>
  <div class="feed">
    {
      exhibits.map((entry) => (
        <ExhibitCard
          exhibit={entry.data.exhibit}
          country={entry.data.country}
          title={entry.data.title}
          category={entry.data.category}
          teaser={entry.data.teaser}
          date={entry.data.date}
          href={withBase(`/exhibits/${entry.slug}/`)}
        />
      ))
    }
  </div>
</BaseLayout>
